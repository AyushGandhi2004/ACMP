# ─────────────────────────────────────────
# NODE MODULES
# Container installs its own node_modules
# Never copy local ones into container
# ─────────────────────────────────────────
node_modules/
dist/


# ─────────────────────────────────────────
# ENVIRONMENT FILES
# Never bake env vars into the image
# ─────────────────────────────────────────
.env
*.env
.env.*


# ─────────────────────────────────────────
# IDE AND OS FILES
# ─────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db


# ─────────────────────────────────────────
# GIT
# ─────────────────────────────────────────
.git/
.gitignore


# ─────────────────────────────────────────
# DOCKER FILES THEMSELVES
# ─────────────────────────────────────────
Dockerfile
.dockerignore


# ─────────────────────────────────────────
# DOCS
# ─────────────────────────────────────────
README.md